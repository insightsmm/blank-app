{
  "name": "TemPO HQ",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "src/App.jsx"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "updateContentCommand": "npm install",
  "postAttachCommand": {
    "server": "npm run dev -- --host 0.0.0.0"
  },
  "portsAttributes": {
    "5173": {
      "label": "TemPO HQ (dev)",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [5173]
}
